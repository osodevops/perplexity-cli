# Maintainer: OSO DevOps <hello@osodevops.io>
pkgname=pplx-bin
pkgver=0.2.0
pkgrel=1
pkgdesc="A fast Perplexity API CLI built in Rust"
arch=('x86_64')
url="https://github.com/osodevops/perplexity-cli"
license=('MIT')
depends=()
provides=('pplx')
conflicts=('pplx')
source=("${url}/releases/download/v${pkgver}/pplx-x86_64-unknown-linux-gnu.tar.gz")
sha256sums=('SKIP')

package() {
    install -Dm755 pplx "${pkgdir}/usr/bin/pplx"

    # Install man page if present
    if [ -f pplx.1 ]; then
        install -Dm644 pplx.1 "${pkgdir}/usr/share/man/man1/pplx.1"
    fi

    # Install license
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
